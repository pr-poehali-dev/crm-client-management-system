{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "GET all candidates",
      "method": "GET",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "POST create candidate",
      "method": "POST",
      "path": "/",
      "body": {
        "action": "create",
        "fullName": "Тестов Тест Тестович",
        "age": "25",
        "criminalRecord": "Нет",
        "chronicDiseases": "Нет",
        "dispensaryRecord": "Нет",
        "notes": "Тестовая запись",
        "docPhotos": [],
        "relationPhotos": [],
        "tickets": [],
        "contractPhotos": [],
        "employeeName": "Тестер",
        "createdAt": "2026-05-21"
      },
      "expectedStatus": 201
    },
    {
      "name": "POST toggle_called — unknown id returns 404",
      "method": "POST",
      "path": "/",
      "body": { "action": "toggle_called", "id": 999999, "called": true },
      "expectedStatus": 404
    },
    {
      "name": "POST set_call_result — unknown id returns 404",
      "method": "POST",
      "path": "/",
      "body": { "action": "set_call_result", "id": 999999, "result": "Недозвон" },
      "expectedStatus": 404
    },
    {
      "name": "POST upload without data returns 400",
      "method": "POST",
      "path": "/",
      "body": { "action": "upload" },
      "expectedStatus": 400
    },
    {
      "name": "POST presign_upload — возвращает uploadUrl и cdnUrl",
      "method": "POST",
      "path": "/",
      "body": { "action": "presign_upload", "name": "photo.jpg", "type": "image/jpeg" },
      "expectedStatus": 200,
      "expectedBody": { "uploadUrl": "string", "cdnUrl": "string" },
      "bodyMatcher": "partial"
    },
    {
      "name": "Webhook — принимает лид без секрета",
      "method": "POST",
      "path": "/",
      "body": {
        "action": "webhook",
        "full_name": "Лидов Лид Лидович",
        "phone": "+79001234500",
        "city": "Москва",
        "source": "test-site"
      },
      "expectedStatus": 200,
      "bodyMatcher": "partial"
    },
    {
      "name": "DMP.ONE webhook — приём лида без секрета",
      "method": "POST",
      "path": "/",
      "body": {
        "action": "dmp",
        "phone": "7(900)123-45-67",
        "name": "Тестов Тест"
      },
      "expectedStatus": 200,
      "bodyMatcher": "partial"
    },
    {
      "name": "GET my_leads — без имени возвращает 400",
      "method": "GET",
      "path": "/?mode=my_leads",
      "expectedStatus": 400
    },
    {
      "name": "GET my_leads — по имени возвращает список",
      "method": "GET",
      "path": "/?mode=my_leads&name=Тестов",
      "expectedStatus": 200
    },
    {
      "name": "POST set_color — unknown id returns 404",
      "method": "POST",
      "path": "/",
      "body": { "action": "set_color", "id": 999999, "color": "#ff0000" },
      "expectedStatus": 401
    },
    {
      "name": "POST assign_leads — без авторизации возвращает 401 или 403",
      "method": "POST",
      "path": "/",
      "body": { "action": "assign_leads", "ids": [999999], "assignedUserId": 1, "assignedTo": "Тест" },
      "expectedStatus": 403
    },
    {
      "name": "GET help — возвращает разделы инструкции",
      "method": "GET",
      "path": "/?mode=help",
      "expectedStatus": 200
    },
    {
      "name": "POST help_save — без авторизации возвращает 403",
      "method": "POST",
      "path": "/",
      "body": { "action": "help_save", "id": 1, "title": "Тест", "icon": "Info", "items": [] },
      "expectedStatus": 403
    }
  ]
}